# API Configuration
# Copy this file to .env and fill in your actual API keys

# AI Provider Selection
# Options: "claude" or "deepseek"
AI_PROVIDER=claude

# Claude/Anthropic Configuration (권장)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Google Gemini Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Alternative key name (either GEMINI_API_KEY or GOOGLE_API_KEY works)
# GOOGLE_API_KEY=your_google_api_key_here

# DeepSeek API Configuration
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Common Runtime Parameters (apply to all providers)
# Sampling temperature, 0.0-1.0 (default: 0.3)
# Lower = more consistent/accurate, Higher = more creative
AI_TEMPERATURE=0.3

# Maximum tokens in response (default: 8192)
AI_MAX_TOKENS=8192

# Request timeout in seconds (default: 120)
AI_TIMEOUT=120

# Maximum retry attempts on failure (default: 3)
AI_MAX_RETRIES=3
